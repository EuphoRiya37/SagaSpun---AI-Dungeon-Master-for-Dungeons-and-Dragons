{
  "expo": {
    "name": "Saga Spun",
    "slug": "saga-spun",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#0D0D0D" },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sagaspun.app"
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#0D0D0D" },
      "package": "com.sagaspun.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      ["expo-image-picker", {
        "photosPermission": "Allow Saga Spun to access your photos for character portraits."
      }]
    ]
  }
}